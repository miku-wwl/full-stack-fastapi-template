        <mxCell id="sec2" value="PART B: AGILE SPRINT PLAN (3 Sprints)" style="text;html=1;strokeColor=none;fillColor=#fff3e0;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#e65100;rounded=1;" parent="1" vertex="1">
