        <mxCell id="s1-swim" value="Sprint 1: Foundation" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=12;fontStyle=1;startSize=24;" parent="1" vertex="1">
          <mxGeometry x="60" y="885" width="580" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="s1-goal" value="Goal: Auth, DB Schema &amp; UI Layout" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#e65100;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="75" y="918" width="280" height="18" as="geometry"/>
