        <mxCell id="s1-tl2" value="⏱ Timeline: Week 9 - Week 10" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#e65100;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="380" y="918" width="240" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s1-tasks" value="Tasks:&#10;- Set up Docker Compose (FastAPI + PostgreSQL + Nginx)&#10;- Implement JWT authentication (register / login / password recovery)&#10;- Design SQLModel ORM schema (User, CurrencyPair, RateSnapshot, Transaction)&#10;- Build React app scaffold with TanStack Router and Tailwind CSS&#10;- Create Dashboard homepage with statistics cards" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=8;textAlign=left;" parent="1" vertex="1">
          <mxGeometry x="75" y="942" width="300" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="s1-deliverables" value="Deliverables:&#10;- Functional login/registration system&#10;- Database schema with Alembic migrations&#10;- Dashboard with real data integration&#10;- Sprint 1 Demo (MVP Ready)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=8;textAlign=left;" parent="1" vertex="1">
          <mxGeometry x="390" y="942" width="230" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="s2-swim" value="Sprint 2: Core Trading" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=12;fontStyle=1;startSize=24;" parent="1" vertex="1">
          <mxGeometry x="680" y="885" width="580" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="s2-goal" value="Goal: Live Rates, Forex &amp; Remittance" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#e65100;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="695" y="918" width="280" height="18" as="geometry"/>
