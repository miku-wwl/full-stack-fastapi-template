        <mxCell id="s2-tl2" value="⏱ Timeline: Week 11 - Week 12" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#e65100;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1000" y="918" width="240" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s2-tasks" value="Tasks:&#10;- Build ForexSimulator with Frankfurter ECB API integration&#10;- Implement 5-second real-time rate polling (background thread)&#10;- Create exchange rate charts (ApexCharts, 24h history)&#10;- Develop remittance form with rate locking &amp; IBAN validation&#10;- Build transaction history with pagination &amp; status filtering" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=8;textAlign=left;" parent="1" vertex="1">
          <mxGeometry x="695" y="942" width="300" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="s2-deliverables" value="Deliverables:&#10;- Real-time forex dashboard&#10;- Cross-border remittance flow&#10;- Transaction history with search&#10;- Sprint 2 Demo (Trading Ready)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=8;textAlign=left;" parent="1" vertex="1">
          <mxGeometry x="1010" y="942" width="230" height="76" as="geometry"/>
        </mxCell>
